{
  "expo": {
    "name": "BookMyShot",
    "slug": "bookmyshot",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "updates": {
      "enabled": false
    },
    "splash": {
      "backgroundColor": "#0A0A0A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.bookmyshot.app"
    },
    "android": {
      "package": "in.bookmyshot.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "navigationBarColor": "#0A0A0A",
      "backgroundColor": "#0A0A0A"
    },
    "plugins": [
      "expo-splash-screen",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4AF37",
          "defaultChannel": "bookmyshot"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#D4AF37",
      "androidMode": "default",
      "androidCollapsedTitle": "BookMyShot"
    },
    "extra": {
      "apiBaseUrl": "https://site--bookmyshot--ykz2mr8mzlrv.code.run/api"
    }
  }
}
