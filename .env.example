PORT=5000

MONGODB_URI=REDACTED_MONGODB_URI

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development

ADMIN_EMAIL=bookmyshott@gmail.com
ADMIN_PASSWORD=REDACTED_PASSWORD


# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here

# Email Configuration
# Emails are sent from: support@bookmyshot.in (transactional) and otp@bookmyshot.in (OTP)
# Admin receives notification emails at ADMIN_EMAIL address
# Ensure bookmyshot.in domain is verified in Resend dashboard

# Cloudinary (Image/Video Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Recovery Email (receives OTPs for admin login/reset)
ADMIN_RECOVERY_EMAIL=bookmyshott@gmail.com

# Payment Collection (UPI)
BMS_UPI_ID=bookmyshot@upi
BMS_QR_IMAGE=/uploads/general/qr-code.png

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=
