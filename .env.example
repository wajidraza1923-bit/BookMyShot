PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bookmyshot?retryWrites=true&w=majority

# JWT
JWT_SECRET=generate_a_strong_random_secret_here
JWT_EXPIRE=7d

# Node Environment
NODE_ENV=development

# Admin Account (created on first startup if no admin exists)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_strong_admin_password

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here

# Email Configuration
# Emails sent from: support@bookmyshot.in (transactional) and otp@bookmyshot.in (OTP)
# Admin receives notification emails at ADMIN_EMAIL address
# Ensure bookmyshot.in domain is verified in Resend dashboard

# Cloudinary (Image/Video Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_ID=

# Site URL (for emails and redirects)
SITE_URL=https://site--bookmyshot--ykz2mr8mzlrv.code.run

# Firebase (Push Notifications via Expo Push API → FCM)
# google-services.json must be placed at android/app/google-services.json for EAS builds
# Download from: Firebase Console → Project Settings → Android app → Download google-services.json
# The Expo Push API handles FCM relay — no Firebase Admin SDK needed on server
# FIREBASE_PROJECT_ID=bookmyshot-xxxxx (only needed if using firebase-admin directly)
